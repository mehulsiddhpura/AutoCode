# Copy this file to: scripts/notify-email.local.ps1  (it is GITIGNORED — never commit it)
# Fill in your own Brevo SMTP credentials and recipient.

$env:BREVO_SMTP_KEY  = "<your-brevo-smtp-key>"        # Brevo > SMTP & API > SMTP key
$env:BREVO_SMTP_LOGIN = "<your-brevo-smtp-login>"     # e.g. 1234abc@smtp-brevo.com
$env:NOTIFY_EMAIL_TO   = "you@example.com"            # where notification emails are sent
$env:NOTIFY_EMAIL_FROM = "you@example.com"            # verified sender in Brevo
